# Optional API keys. Tool works without them but with reduced limits / coverage.

# Birdeye — Solana data (token overview, OHLCV by mint, security). Free tier 30k CU/mo.
# Sign up at https://bds.birdeye.so
BIRDEYE_API_KEY=

# Helius — Solana RPC + holder enumeration. Free tier 1M credits/mo.
# Sign up at https://dashboard.helius.dev
HELIUS_API_KEY=

# Etherscan — verified contract source. Free tier 5 rps / 100k req/day.
# Sign up at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# GoPlus — token security (multi-chain). Optional access token raises rate limit.
# Free without auth at ~30 req/min. https://gopluslabs.io
GOPLUS_ACCESS_TOKEN=
